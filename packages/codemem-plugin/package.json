{
  "name": "@mazac-fox/codemem-plugin",
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "description": "OpenCode plugin and CLI for Codemem code-graph advisory tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jackmazac/codemem.git",
    "directory": "packages/codemem-plugin"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "cd ../.. && bun install && bun run build && bun ./scripts/stage-codemem-daemon-bin.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "codemem": "./dist/cli.js"
  },
  "files": [
    "bin",
    "dist",
    "package.json"
  ],
  "dependencies": {
    "@mazac-fox/codemem-shared": "^0.1.0",
    "@mazac-fox/opencode-fleet-contracts": "^0.1.0",
    "@mazac-fox/opencode-host-adapter": "^0.1.0",
    "@opencode-ai/plugin": "1.14.31"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  }
}
