{
  // Entrypoints that define the live graph roots for dead-code and reachability analysis.
  "entrypoints": ["src/index.ts", "apps/*/src/main.ts"],

  // Files and folders ignored by the daemon indexer.
  "ignore": [
    "node_modules/**",
    "**/node_modules/**",
    ".opencode/**",
    "dist/**",
    "**/dist/**",
    "build/**",
    ".next/**",
    "coverage/**",
    "**/*.generated.ts",
    "**/*.generated.tsx",
    "**/*.gen.ts",
    "**/*.gen.tsx"
  ],

  // Optional package / layer boundaries for package-cycle reporting.
  "packageBoundaries": [
    { "root": "packages/*", "kind": "workspace" },
    { "root": "apps/*", "kind": "layer", "name": "apps" }
  ],

  "layers": {
    "astClones": true,
    "simhashClones": true,
    "typeShapes": true,
    "symbolGraph": true,
    "apiDrift": true,
    "sessionConflicts": true,
    "dynamicDeadCode": true
  },

  "thresholds": {
    "minCloneTokens": 24,
    "minCloneStatements": 3,
    "simhashHammingRadius": 6,
    "maxFindings": 50,
    "typeShapeMinMembers": 3,
    "sessionConflictOverlap": 0.25,
    "sessionConflictDecayMs": 900000,
    "promptInjectionMinConfidence": 0.8
  },

  "daemon": {
    "stateDirectory": ".git/codemem",
    "maxPayloadBytes": 4194304,
    "healthTimeoutMs": 250,
    "requestTimeoutMs": 3000,
    "spawnTimeoutMs": 2500,
    "binaryPath": "./bin/codemem-daemon"
  },

  "telemetry": {
    "enabled": true,
    "retainDays": 14,
    "maxLogBytes": 8388608,
    "structuredLocalOnly": true
  },

  "promptInjection": {
    "enabled": true,
    "mode": "turn",
    "minSeverity": "warn",
    "maxSignalsPerTurn": 4,
    "cooldownMs": 2000
  },

  "maxFindings": 50
}
